#!/usr/bin/env bash
# This script is generated by chezmoi from run_onchange_install-paru.sh.tmpl
# It runs automatically when paru-packages.txt changes (via run_onchange_)

set -euo pipefail

# Package list generated from paru-packages.txt
PACKAGES=(
{{ $srcDir := .chezmoi.sourceDir }}
{{ $pkgFile := printf "%s/paru-packages.txt" $srcDir | readValueAs "string" }}
{{ $lines := $pkgFile | splitList "\n" }}
{{ range $line := $lines }}
{{- if and (ne (trimspace $line) "") (not (hasPrefix "#" (trimspace $line))) }}
    "{{ . }}"
{{- end }}
{{- end }}
)

# Install missing packages via paru
TO_INSTALL=()
for pkg in "${PACKAGES[@]}"; do
    if ! pacman -Q "$pkg" &>/dev/null && ! paru -Q "$pkg" &>/dev/null; then
        TO_INSTALL+=("$pkg")
    fi
done

if [[ ${#TO_INSTALL[@]} -eq 0 ]]; then
    echo "All packages already installed."
    exit 0
fi

echo "Installing ${#TO_INSTALL[@]} packages via paru..."
paru -S --needed --noconfirm "${TO_INSTALL[@]}"

echo "Done!"