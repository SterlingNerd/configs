{
  "cli_default_open_behavior": "existing_window",
  "agent": {
    "default_model": {
      "provider": "openai",
      "model": "nvidia/nemotron-3-super-120b-a12b:free",
      "enable_thinking": true,
    },
    "favorite_models": [],
    "model_parameters": [],
    "tool_permissions": {
      "default": "confirm",
      "tools": {
        "read_file": { "default": "allow" },
        "find_path": { "default": "allow" },
        "grep": { "default": "allow" },
        "list_directory": { "default": "allow" },
        "terminal": {
          "default": "confirm",
          "always_deny": [
            { "pattern": ">" },
            { "pattern": ">>" },
            { "pattern": "rm\\s+" },
          ],
        },
      },
    },
  },
  "base_keymap": "VSCode",
  "project_panel": {
    "dock": "left",
  },
  "language_models": {
    "openai": {
      "api_url": "https://bifrost.sterling.digital/v1",
      "available_models": [
        {
          "name": "nvidia/nemotron-3-super-120b-a12b:free",
          "max_tokens": 256000,
        },
      ],
    },
  },
}
